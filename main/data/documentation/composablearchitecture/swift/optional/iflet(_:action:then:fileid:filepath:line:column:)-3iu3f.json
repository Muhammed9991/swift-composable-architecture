ble key path from parent state to a property containing optional","type":"text"},{"type":"text","text":" "},{"type":"text","text":"child state."}],"type":"paragraph"}]},{"name":"toWrappedAction","content":[{"inlineContent":[{"text":"A case path from parent action to a case containing child actions.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"A reducer that will be invoked with child actions against non-optional child","type":"text"},{"type":"text","text":" "},{"text":"state.","type":"text"}]}],"name":"wrapped"},{"content":[{"inlineContent":[{"text":"The fileID.","type":"text"}],"type":"paragraph"}],"name":"fileID"},{"content":[{"inlineContent":[{"text":"The filePath.","type":"text"}],"type":"paragraph"}],"name":"filePath"},{"name":"line","content":[{"type":"paragraph","inlineContent":[{"text":"The line.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The column."}],"type":"paragraph"}],"name":"column"}]},{"kind":"content","content":[{"text":"Return Value","type":"heading","anchor":"return-value","level":2},{"inlineContent":[{"text":"A reducer that combines the child reducer with the parent reducer.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"inlineContent":[{"text":"For example, if a parent feature holds onto a piece of optional child state, then it can","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"perform its core logic "},{"inlineContent":[{"type":"text","text":"and"}],"type":"emphasis"},{"text":" the child’s logic by using the ","type":"text"},{"code":"ifLet","type":"codeVoice"},{"type":"text","text":" operator:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@Reducer","struct Parent {","  struct State {","    var child: Child.State?","    \/\/ ...","  }","  enum Action {","    case child(Child.Action)","    \/\/ ...","  }","","  var body: some Reducer<State, Action> {","    Reduce { state, action in","      \/\/ Core logic for parent feature","    }","    .ifLet(\\.child, action: \\.child) {","      Child()","    }","  }","}"]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"ifLet"},{"type":"text","text":" operator does a number of things to try to enforce correctness:"}]},{"items":[{"content":[{"inlineContent":[{"text":"It forces a specific order of operations for the child and parent features. It runs the","type":"text"},{"type":"text","text":" "},{"text":"child first, and then the parent. If the order was reversed, then it would be possible for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the parent feature to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" out the child state, in which case the child feature would not"},{"type":"text","text":" "},{"text":"be able to react to that action. That can cause subtle bugs.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"It automatically cancels all child effects when it detects the child’s state is "},{"code":"nil","type":"codeVoice"},{"type":"text","text":"’d"},{"text":" ","type":"text"},{"type":"text","text":"out."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Automatically "},{"code":"nil","type":"codeVoice"},{"type":"text","text":"s out child state when an action is sent for alerts and confirmation"},{"text":" ","type":"text"},{"text":"dialogs.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"See "},{"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Reducer\/ifLet(_:action:destination:fileID:filePath:line:column:)-4ub6q","isActive":true},{"type":"text","text":" for a more advanced operator suited"},{"text":" ","type":"text"},{"type":"text","text":"to navigation."}],"type":"paragraph"}],"kind":"content"}],"identifie