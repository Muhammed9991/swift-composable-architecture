aph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"It adds a "},{"code":"send","type":"codeVoice"},{"type":"text","text":" method to the view that you can use instead of "},{"code":"store.send","type":"codeVoice"},{"type":"text","text":". This allows you"},{"text":" ","type":"text"},{"type":"text","text":"to send view actions more simply, without wrapping the action in "},{"type":"codeVoice","code":".view(…)"},{"text":":","type":"text"}]},{"code":[" Button(\"Login\") {","-  store.send(.view(.loginButtonTapped))","+  send(.loginButtonTapped)"," }"],"syntax":"diff","type":"codeListing"}]},{"content":[{"inlineContent":[{"type":"text","text":"It creates warning diagnostics if you try sending actions through "},{"code":"store.send","type":"codeVoice"},{"type":"text","text":" rather than"},{"text":" ","type":"text"},{"text":"using the ","type":"text"},{"code":"send","type":"codeVoice"},{"text":" method on the view:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["Button(\"Login\") {","  store.send(.view(.loginButtonTapped))","\/\/┬─────────","\/\/╰─ ⚠️ Do not use 'store.send' directly when using '@ViewAction'","}"],"type":"codeListing"}]}]}],"kind":"content"}],"abstract":[{"type":"text","text":"Provides a view with access to a feature’s "},{"isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/ViewAction","type":"reference"},{"text":"s.","type":"text"}],"metadata":{"fragments":[{"text":"macro","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ViewAction","kind":"identifier"},{"text":"<","kind":"text"},{"kind":"genericParameter","text":"R"},{"kind":"text","text":">("},{"text":"for","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"R"},{"text":".Type)","kind":"text"}],"role":"symbol","modules":[{"name":"ComposableArchitecture"}],"externalID":"s:22ComposableArchitecture10ViewAction3foryxm_tcAA7ReducerRzAaB0D0Rpzlufm"