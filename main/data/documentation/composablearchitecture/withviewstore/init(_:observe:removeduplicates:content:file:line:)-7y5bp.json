ViewState"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","text":"ViewAction"},{"text":">) -> ","kind":"text"},{"kind":"typeIdentifier","text":"Content"},{"text":", ","kind":"text"},{"text":"file","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:s12StaticStringV","kind":"typeIdentifier","text":"StaticString"},{"kind":"text","text":" = "},{"kind":"keyword","text":"#fileID"},{"kind":"text","text":", "},{"kind":"externalParam","text":"line"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Su","kind":"typeIdentifier","text":"UInt"},{"text":" = ","kind":"text"},{"kind":"keyword","text":"#line"},{"text":")","kind":"text"}]}],"kind":"declarations"},{"parameters":[{"name":"store","content":[{"type":"paragraph","inlineContent":[{"text":"A store.","type":"text"}]}]},{"name":"toViewState","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A function that transforms store state into observable view state. All"},{"text":" ","type":"text"},{"type":"text","text":"changes to the view state will cause the "},{"type":"codeVoice","code":"WithViewStore"},{"type":"text","text":" to re-compute its view."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"A function to determine when two "},{"type":"codeVoice","code":"ViewState"},{"text":" values are equal. When values","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"are equal, repeat view computations are removed."}],"type":"paragraph"}],"name":"isDuplicate"},{"name":"content","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A function that can generate content from a view store."}]}]},{"name":"file","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The file."}]}]},{"name":"line","content":[{"inlineContent":[{"text":"The line.","type":"text"}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/WithViewStore"},{"text":" will re-compute its body for ","type":"text"},{"inlineContent":[{"text":"any","type":"text"}],"type":"emphasis"},{"type":"text","text":" change to the state it holds. Often the"},{"text":" ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store","type":"reference","isActive":true},{"type":"text","text":" that we want to observe holds onto a lot more state than is necessary to render a"},{"text":" ","type":"text"},{"text":"view. It may hold onto the state of child features, or internal state for its logic.","type":"text"}]},{"inlineContent":[{"type":"text","text":"It can be important to transform the "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store","isActive":true,"type":"reference"},{"type":"text","text":"’s state into something smaller for observation."},{"type":"text","text":" "},{"type":"text","text":"This will help minimize the number of times your view re-computes its body, and can even avoid"},{"type":"text","text":" "},{"text":"certain SwiftUI bugs that happen due to over-rendering.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The way to do this is to use the "},{"type":"codeVoice","code":"observe"},{"text":" argument of this initializer. It allows you to","type":"text"},{"type":"text","text":" "},{"text":"turn the full state into a smaller data type, and only changes to that data type will trigger","type":"text"},{"type":"text","text":" "},{"type":"text","text":"a body re-computation."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For example, if your application uses a tab view, then the root state may hold the state"},{"text":" ","type":"text"},{"type":"text","text":"for each tab as well as the currently selected tab:"}],"type":"paragraph"},{"syntax":"swift","code":["@Reducer","struct AppFeature {","  enum Tab { case activity, search, profile }","  struct State {","    var activity: Activity.State","    var search: Search.State","    var profile: Profile.State","    var selectedTab: Tab","  }","  \/\/ ...","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"In order to construct a tab view you need to observe this state because changes to"},{"text":" ","type":"text"},{"code":"selectedTab","type":"codeVoice"},{"text":" need to make SwiftUI update the visual state of the UI. However, you do not","type":"text"},{"type":"text","text":" "},{"type":"text","text":"need to observe changes to "},{"type":"codeVoice","code":"activity"},{"type":"text","text":", "},{"type":"codeVoice","code":"search"},{"type":"text","text":" and "},{"type":"codeVoice","code":"profile"},{"text":". Those are only necessary for","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"those child features, and changes to that state should not cause our tab view to re-compute"},{"type":"text","text":" "},{"text":"itself.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["struct AppView: View {","  let store: StoreOf<AppFeature>","","  var body: some View {","    WithViewStore(self.store, observe: \\.selectedTab) { viewStore in","      TabView(selection: viewStore.binding(send: { .tabSelected($0) }) {","        ActivityView(","          store: self.store.scope(state: \\.activity, action: \\.activity)","        )","        .tag(AppFeature.Tab.activity)","        SearchView(","          store: self.store.scope(state: \\.search, action: \\.search)","        )","        .tag(AppFeature.Tab.search)","        ProfileView(","          store: self.store.scope(state: \\.profile, action: \\.profile)","        )","        .tag(AppFeature.Tab.profile)","      }","    }","  }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"To read more about this performance technique, read the "},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Performance","isActive":true,"type":"reference"},{"text":" article.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"deprecationSummary":[{"inlineContent":[{"type":"text","text":"Use '@ObservableState', instead. See the following migration guide for more information: https:\/\/pointfreeco.github.io\/swift-composable-architecture\/main\/documentation\/composablearchitecture\/migratingto1.7#Using-ObservableState"}],"type":"paragraph"}],"metadata":{"roleHeading":"Initializer","externalID":"s:22ComposableArchitecture13WithViewStoreV_7observe16removeDuplicates7content4file4lineACyxq_q0_GAA0E0Cyqd__q_G_xqd__cSbx_xtcq0_AA0dE0Cyxq_Gcs12StaticStringVSutclufc","symbolKind":"init","fragments":[{"kind":"identifier","text":"init"},{"text":"<","kind":"text"},{"text":"State","kind":"genericParameter"},{"text":">(","kind":"text"},{"preciseIdentifier":"s:22ComposableArchitecture5StoreC","text":"Store","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"State","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","text":"ViewAction"},{"text":">, ","kind":"text"},{"text":"observe","kind":"externalParam"},{"text":": (","kind":"text"},{"kind":"typeIdentifier","text":"State"},{"kind":"text","text":") -> "},{"text":"ViewState","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"removeDuplicates","kind":"externalParam"},{"text":": (","kind":"text"},{"kind":"typeIdentifier","text":"ViewState"},{"text":", ","kind":"text"},{"text":"ViewState","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"content"},{"kind":"text","text":": ("},{"kind":"typeIdentifier","text":"ViewStore","preciseIdentifier":"s:22ComposableArchitecture9ViewStoreC"},{"text":"<","kind":"text"},{"kind":"typeIdentifier","text":"ViewState"},{"text":", ","kind":"text"},{"text":"ViewAction","kind":"typeIdentif